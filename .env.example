# China Travel Map - Environment Configuration
# Copy this file to .env and fill in your values

# 高德地图 Web 服务 API Key（必填）
# 获取：https://console.amap.com/ → 应用管理
AMAP_KEY=your_amap_webservice_key_here

# /api/seed 接口的访问令牌（可选，建议设置）
# 生成：openssl rand -hex 32
SEED_TOKEN=

# 允许跨域访问的域名（逗号分隔）
# 生产环境只填你的域名，不要用 *
ALLOWED_ORIGINS=http://localhost:8765

# 服务器配置（仅部署用）
SERVER_HOST=
SERVER_USER=
SERVER_PASSWORD=
SERVER_PORT=22
